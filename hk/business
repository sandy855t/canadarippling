            line-height: 1.2;
            margin: 0 0 30px 0;
        }
        
        .service-image {
            width: 100%;
            height: 300px;
            object-fit: contain;
            display: block;
            margin-top: auto;
            border-radius: 4px;
        }

        footer {
            text-align: center;
            margin-top: 80px;
            padding-top: 20px;
